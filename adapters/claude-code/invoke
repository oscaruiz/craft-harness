#!/usr/bin/env bash
# craft-harness adapter: Claude Code, headless mode (adapters/CONTRACT.md).
# One agent turn: `claude -p` on the prompt, cwd = workdir.
#
# Permissions (D38, replacing the D23 skip-all): a headless turn cannot answer
# an interactive permission prompt, so everything a phase legitimately needs
# must be pre-authorized — and nothing else. Where D23's stopgap was
# --dangerously-skip-permissions (any command at all), the turn now runs under
# an explicit scoped allowlist:
#   Edit / Write            file changes, confined to the CLI's allowed dirs
#   Bash(git:*)             the phase's own git work (D23: config/add/commit)
#   Bash(<declared cmd>)    each project-contract command (test:/quality:/
#     + Bash(<cmd>:*)       accept:/mutation:), exact and with appended args —
#                           parsed structurally from the workdir's
#                           project.prompt, never guessed from prose
#   --add-dir <state dir>   the runner's session dir (handoffs/spec/diff) when
#                           a phase works in a detached worktree
# Agent-tool network egress (WebFetch/WebSearch) is denied explicitly; any
# undeclared Bash (curl, wget, ...) is off the allowlist and a headless turn
# denies what it cannot ask about. This contains the D30 threat model —
# carelessness, not malice: a declared toolchain (mvn, a bash script) can run
# arbitrary code by design, so the allowlist is an accident boundary, not a
# hostile-agent sandbox (that remains the declined v0.2 OS-isolation, D38).
set -euo pipefail

usage() { echo "usage: invoke --workdir <dir> --prompt-file <file>" >&2; exit 2; }

FORK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

WORKDIR=""
PROMPT=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --workdir) WORKDIR="${2:-}"; shift 2 ;;
    --prompt-file) PROMPT="${2:-}"; shift 2 ;;
    *) usage ;;
  esac
done
[[ -d "$WORKDIR" && -f "$PROMPT" ]] || usage

ALLOWED=("Edit" "Write" "Bash(git:*)")
# Declared project commands become exact + args-appended Bash rules. An absent
# or unparseable contract contributes nothing: the runners fail-closed on an
# invalid contract long before any phase runs, so degrading a direct invoke to
# the baseline allowlist is safe, never fail-open.
if [[ -f "$WORKDIR/project.prompt" ]]; then
  while IFS=$'\t' read -r kind a b c; do
    cmd=""
    case "$kind" in
      TEST|ACCEPT) cmd="$a" ;;
      QUALITY) cmd="$b" ;;
      MUTATION) cmd="$c" ;;
    esac
    [[ -n "$cmd" ]] || continue
    ALLOWED+=("Bash($cmd)" "Bash($cmd:*)")
  done < <(bash "$FORK_ROOT/bin/parse-project" "$WORKDIR/project.prompt" 2>/dev/null || true)
fi

# Worktree phases (solo verify, six qa) write their handoff and read spec/diff
# under the runner's session state dir, which sits OUTSIDE their workdir; grant
# that one directory. The runner exports the handoffs dir per phase.
EXTRA_DIRS=()
for hd in "${SIX_HANDOFFS_DIR:-}" "${SOLO_HANDOFFS_DIR:-}"; do
  [[ -n "$hd" && -d "$hd" ]] || continue
  EXTRA_DIRS+=(--add-dir "$(cd "$hd/.." && pwd)")
done

cd "$WORKDIR"
# ${arr[@]+...} keeps the empty-array expansion legal under bash 3.2 set -u (macOS).
exec claude -p "$(cat "$PROMPT")" \
  ${EXTRA_DIRS[@]+"${EXTRA_DIRS[@]}"} \
  --disallowedTools "WebFetch" "WebSearch" \
  --allowedTools "${ALLOWED[@]}"
