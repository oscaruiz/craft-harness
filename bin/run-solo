#!/usr/bin/env bash
# craft-harness run-solo — milestone 4, behaviors B2/B3/B4.
#
#   run-solo --project <path> --adapter <name-or-dir>
#            [--approval-timeout <s>] [--phase-timeout <s>]
#            [--retry-cap <n>] [--run-timeout <s>] [--command-timeout <s>]
#
# The solo-pack: a sequential runner of our own — no tmux, no daemon. Three
# phases, each a fresh headless `invoke` (adapters/CONTRACT.md Mode 1) in its own
# workdir with no inherited transcript; what one phase learned reaches the next
# only through the structured handoff (B1), which run-solo validates before the
# next phase starts. Phases:
#   specify   — produces spec + documental Gherkin (scenario IDs); then the run
#               PAUSES for the owner's approval (R6). No auto-approve path.
#   code      — implements the approved spec, commits the candidate on the
#               enforced branch; project gates are later executed by the runner.
#   verify    — runs in a clean git worktree checked out at the CANDIDATE commit
#               (B3), inputs restricted to spec + diff + handoffs + tool output.
#
# Session state is persistent under <project>/.craft-harness/solo/current so a
# crash mid-run is visible as "session in flight" (R8/D6, detected by doctor).
# The gate is a resume point: invocation 1 runs specify and pauses; the owner
# approves; a later invocation resumes into code+verify. Exit 0 = paused-cleanly
# or completed-and-green; non-zero = a phase or handoff failed (attributed).
set -euo pipefail

FORK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
die() { echo "run-solo: $*" >&2; exit 1; }
usage() {
  echo "usage: run-solo --project <path> --adapter <name-or-dir> [--pack <branch>] [--approval-timeout <s>] [--phase-timeout <s>] [--retry-cap <n>] [--run-timeout <s>] [--command-timeout <s>]" >&2
  exit 2
}

PROJECT=""; ADAPTER=""; PACK="solo-pack"; APPROVAL_TIMEOUT=0
PHASE_TIMEOUT=0; RETRY_CAP=1; RUN_TIMEOUT=0; COMMAND_TIMEOUT=600
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project) PROJECT="${2:-}"; shift 2 ;;
    --adapter) ADAPTER="${2:-}"; shift 2 ;;
    --pack) PACK="${2:-}"; shift 2 ;;
    --approval-timeout) APPROVAL_TIMEOUT="${2:-}"; shift 2 ;;
    --phase-timeout) PHASE_TIMEOUT="${2:-}"; shift 2 ;;
    --retry-cap) RETRY_CAP="${2:-}"; shift 2 ;;
    --run-timeout) RUN_TIMEOUT="${2:-}"; shift 2 ;;
    --command-timeout) COMMAND_TIMEOUT="${2:-}"; shift 2 ;;
    *) usage ;;
  esac
done
[[ -n "$PROJECT" && -n "$ADAPTER" ]] || usage
[[ -d "$PROJECT/.git" ]] || die "not a git repository: $PROJECT"
# Resolve PROJECT to an absolute path (D21): we inject the handoff destination
# into the phase prompt as a literal path, and it must be byte-identical to the
# path the runner later reads. A relative PROJECT (with the agent cd'd into its
# workdir) would make the two diverge.
PROJECT="$(cd "$PROJECT" && pwd)"
command -v bb >/dev/null 2>&1 || die "babashka (bb) is required"
[[ "$COMMAND_TIMEOUT" =~ ^[1-9][0-9]*$ ]] || die "--command-timeout must be a positive integer"

# Runner-private authentication anchor for retained command evidence (D29/m6).
# Resolve it before invoking any phase, then remove the override from the phase
# environment. The key lives outside the audited project and is never exposed in
# a prompt, handoff, worktree, manifest, or agent environment.
PRIVATE_STATE_ROOT="${CRAFT_HARNESS_PRIVATE_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/craft-harness}"
unset CRAFT_HARNESS_PRIVATE_STATE
mkdir -p "$PRIVATE_STATE_ROOT"
PRIVATE_STATE_ROOT="$(cd "$PRIVATE_STATE_ROOT" && pwd)"
case "$PRIVATE_STATE_ROOT/" in
  "$PROJECT"/*) die "runner-private state must be outside the project working tree: $PRIVATE_STATE_ROOT" ;;
esac
PROJECT_STATE_ID="$(printf '%s' "$PROJECT" | sha256sum | awk '{print $1}')"
PRIVATE_EVIDENCE_DIR="$PRIVATE_STATE_ROOT/solo/$PROJECT_STATE_ID"
COMMAND_EVIDENCE_KEY="$PRIVATE_EVIDENCE_DIR/commands.key"
APPROVAL_TOKEN="$PRIVATE_EVIDENCE_DIR/approval.token"

# R6 precondition: an approved task.md must exist before any phase runs.
[[ -f "$PROJECT/task.md" ]] || die "task.md not found in $PROJECT — R6: run-solo refuses to start without a task"

# D27: the real-project contract is required and fail-closed. It supplies the
# owned paths, exact test command, and optional ordered quality commands.
CONTRACT_PARSER="$FORK_ROOT/bin/parse-project"
CONTRACT_OUT="$(bash "$CONTRACT_PARSER" "$PROJECT/project.prompt" 2>&1)" \
  || die "invalid project contract — $CONTRACT_OUT"
declare -a PROJECT_OWNS=() QUALITY_NAMES=() QUALITY_COMMANDS=()
PROJECT_TEST_CMD=""
while IFS=$'\t' read -r kind a b; do
  case "$kind" in
    OWN) PROJECT_OWNS+=("$a") ;;
    TEST) PROJECT_TEST_CMD="$a" ;;
    QUALITY) QUALITY_NAMES+=("$a"); QUALITY_COMMANDS+=("$b") ;;
  esac
done <<< "$CONTRACT_OUT"
(( ${#PROJECT_OWNS[@]} > 0 )) || die "invalid project contract — no owned paths"
[[ -n "$PROJECT_TEST_CMD" ]] || die "invalid project contract — no test command"

# Pre-existing tracked edits can be swept into the agent's candidate and cannot
# be attributed to this run. Untracked files are allowed; the owned-scope check
# still rejects them if the agent commits them outside the contract.
git -C "$PROJECT" diff --quiet && git -C "$PROJECT" diff --cached --quiet \
  || die "tracked working tree is dirty — commit or stash tracked changes before running"

# --- adapter resolution (same rule as run-scenario) -------------------------
case "$ADAPTER" in
  */*) ADAPTER_DIR="$ADAPTER" ;;
  *) if [[ -d "$ADAPTER" ]]; then ADAPTER_DIR="$ADAPTER"; else ADAPTER_DIR="$FORK_ROOT/adapters/$ADAPTER"; fi ;;
esac
[[ -d "$ADAPTER_DIR" ]] || die "adapter '$ADAPTER' not found at $ADAPTER_DIR"
for exe in invoke info; do
  [[ -x "$ADAPTER_DIR/$exe" ]] || die "adapter '$ADAPTER': missing executable '$exe'"
done

# --- pack resolution (D16): the solo-pack branch owns the phase content -----
# run-solo owns the phase STRUCTURE (the R6 gate, the verify worktree at the
# candidate commit, commit-on-enforced-branch, the handoff routing header); the
# pack branch owns each phase's prompt BODY and declares the ordered phase list.
# We read that content straight from the branch in the fork — exactly how the
# launcher resolves --pack — so no per-pack entry in MANAGED_FILES.manifest is
# needed (role files are per-pack; the manifest is a single global list).
git -C "$FORK_ROOT" rev-parse --verify --quiet "$PACK^{commit}" >/dev/null 2>&1 \
  || die "pack branch '$PACK' not found in the fork"
PACK_CONF="$(git -C "$FORK_ROOT" show "$PACK:swarmforge/swarmforge.conf" 2>/dev/null)" \
  || die "pack '$PACK' has no swarmforge/swarmforge.conf"
declare -A PACK_ROLE=()
CONF_PHASES=()
while read -r kw name _agent role _rest; do
  [[ "$kw" == "phase" ]] || continue
  CONF_PHASES+=("$name")
  PACK_ROLE["$name"]="${role:-$name}"
done <<< "$PACK_CONF"
SOLO_SEQUENCE="specify code verify"
[[ "${CONF_PHASES[*]}" == "$SOLO_SEQUENCE" ]] \
  || die "pack '$PACK' phase list (${CONF_PHASES[*]:-none}) does not match run-solo's phase sequence ($SOLO_SEQUENCE)"
for ph in $SOLO_SEQUENCE; do
  git -C "$FORK_ROOT" show "$PACK:swarmforge/roles/${PACK_ROLE[$ph]}.prompt" >/dev/null 2>&1 \
    || die "pack '$PACK' missing role prompt for phase '$ph' (swarmforge/roles/${PACK_ROLE[$ph]}.prompt)"
done

# a phase's prompt body, read from the pack branch (structure-free content).
load_role_body() { git -C "$FORK_ROOT" show "$PACK:swarmforge/roles/${PACK_ROLE[$1]}.prompt"; }

# --- paths ------------------------------------------------------------------
STATE="$PROJECT/.craft-harness/solo/current"
SPEC="$STATE/spec"
HANDOFFS="$STATE/handoffs"
LOGS="$STATE/logs"
APPROVAL="$STATE/approval"
PROMPTS="$STATE/prompts"
MANIFEST="$STATE/manifest.json"
PHASES_TSV="$STATE/phases.tsv"
COMMANDS_TSV="$STATE/commands.tsv"
STATUS="$STATE/status"
FAILURE="$STATE/failure"
VALIDATE="$FORK_ROOT/bin/handoff-validate.bb"
MANIFEST_BB="$FORK_ROOT/adapters/scenario_manifest.bb"

now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ; }
set_status() { printf '%s\n' "$1" > "$STATUS"; }

# The handoff header (routing metadata) is RUN-SOLO's to own, not the agent's:
# the phase writes only the five content sections to $SOLO_HANDOFF, and run-solo
# prepends the header here. This keeps id/from/to/phase/created_at (and the
# candidate commit) authoritative and correct regardless of how a real agent
# formats its body — an agent that adds a title just contributes a harmless
# extra section.
finalize_handoff() { # <phase> <to> [commit]
  local phase="$1" to="$2" commit="${3:-}"
  local h="$HANDOFFS/$phase.handoff"
  [[ -f "$h" ]] || fail_phase "$phase" "no handoff body written to $h"
  local body; body="$(cat "$h")"
  {
    echo "id: $(date -u +%Y%m%dT%H%M%S%NZ)_$phase"
    echo "from: $phase"
    echo "to: $to"
    echo "phase: $phase"
    echo "created_at: $(now_iso)"
    [[ -n "$commit" ]] && echo "commit: $commit"
    echo
    printf '%s\n' "$body"
  } > "$h"
}

# A failed/broken verify phase must not leak its worktree (R10 reliable
# cancellation). fail_phase exits, firing this trap.
VWD=""
cleanup_worktree() { [[ -n "$VWD" ]] && git -C "$PROJECT" worktree remove --force "$VWD" 2>/dev/null || true; }
trap cleanup_worktree EXIT

ADAPTER_INFO="$("$ADAPTER_DIR/info" 2>/dev/null || echo "$ADAPTER unknown")"

write_manifest() { # <outcome>
  local command_evidence_mac=""
  if [[ -f "$COMMAND_EVIDENCE_KEY" && -f "$COMMANDS_TSV" ]]; then
    command_evidence_mac="$(command_evidence_mac)"
  fi
  local args=(
    "$MANIFEST" "$PHASES_TSV"
    "pack=$PACK" "project=$PROJECT" "adapter=$ADAPTER" "adapter_info=$ADAPTER_INFO"
    "fork_commit=$(git -C "$FORK_ROOT" rev-parse HEAD)"
    "enforced_branch=$(cat "$STATE/enforced_branch" 2>/dev/null || echo '?')"
    "baseline_commit=$(cat "$STATE/baseline_commit" 2>/dev/null || echo '?')"
    "candidate_commit=$(cat "$STATE/candidate_commit" 2>/dev/null || echo '')"
    "retry_cap=$RETRY_CAP" "phase_timeout_s=$PHASE_TIMEOUT" "run_timeout_s=$RUN_TIMEOUT"
    "command_timeout_s=$COMMAND_TIMEOUT"
    "command_evidence_mac=$command_evidence_mac"
    "outcome=$1"
  )
  bb "$MANIFEST_BB" "${args[@]}" >/dev/null
}

command_evidence_mac() {
  local candidate
  candidate="$(cat "$STATE/candidate_commit" 2>/dev/null || true)"
  { cat "$COMMAND_EVIDENCE_KEY"; printf '%s\n%s\n' "$PROJECT" "$candidate"; \
    cat "$COMMANDS_TSV"; cat "$COMMAND_EVIDENCE_KEY"; } \
    | sha256sum | awk '{print $1}'
}

initialize_command_evidence_key() {
  mkdir -p "$PRIVATE_EVIDENCE_DIR"
  chmod 700 "$PRIVATE_STATE_ROOT/solo" "$PRIVATE_EVIDENCE_DIR"
  if [[ ! -f "$COMMAND_EVIDENCE_KEY" ]]; then
    umask 077
    head -c 32 /dev/urandom > "$COMMAND_EVIDENCE_KEY"
  fi
  chmod 600 "$COMMAND_EVIDENCE_KEY"
}

fail_phase() { # <phase> <reason>
  printf 'FAILED at phase %s: %s\n' "$1" "$2" > "$FAILURE"
  set_status "failed"
  write_manifest "failed"
  die "phase '$1' failed: $2"
}

write_prompt() { # <phase> <body>
  printf 'PHASE: %s\n\n%s\n' "$1" "$2" > "$PROMPTS/$1.prompt"
}

# The handoff-section instructions run-solo appends to every phase prompt. The
# destination is injected as a LITERAL absolute path on its own `HANDOFF_PATH:`
# line (D21) — never as a variable name the agent must shell-expand — because a
# confined headless agent (adapter's --permission-mode acceptEdits) cannot
# expand $SOLO_HANDOFF, and a guessed filename fails the run. $SOLO_HANDOFF is
# still exported (run_phase) as a convenience, but routing no longer depends on
# any agent-side expansion. Per-phase because each phase has its own path.
handoff_instructions() { # <phase>
  local dest="$HANDOFFS/$1.handoff"
  cat <<EOF
Write your handoff to this exact absolute file path, given literally on the next line:
HANDOFF_PATH: $dest
Use that literal path. It is also exported as \$SOLO_HANDOFF, but do NOT rely on shell/variable expansion — write to the literal path above. Write ONLY these five markdown sections, each introduced by a '# ' heading, in this exact order — do NOT write any id/from/to/created_at header and do NOT put a title before the first section (the runner adds the routing header itself):

# done
- <what this phase actually accomplished>
# decisions
- <choices you made and why — this MUST be non-empty if you changed or committed anything>
# assumptions
- <what you took for granted>
# open items
- <unresolved items for a later phase, or '- none'>
# commands executed
- <the commands you ran>

Every section must be present. Use bullet lines under each heading.
EOF
}

# The project's declared test command (D22). A single strict `test:` line in
# project.prompt, e.g. `test: mvn -q test -pl src/core`. run-solo injects it into
# the code/verify prompts (below) so those phases target the PROJECT's own test
# entrypoint, never a harness toy default. The strict contract is required.
project_test_cmd() {
  printf '%s' "$PROJECT_TEST_CMD"
}

# Injected into the code/verify prompts (D22) as a literal TEST_CMD line — the
# same pattern as HANDOFF_PATH (D21): the runner hands the agent the resolved
# value, never relying on the agent to parse project.prompt itself.
test_cmd_instructions() { # <command>
  # The TEST_CMD line must NOT be the block's last line: seed_prompts joins these
  # blocks via command substitution, which strips a trailing newline — so a last
  # TEST_CMD line would have the next instruction bleed onto it (D22 coda). A line
  # after it keeps TEST_CMD cleanly newline-terminated. The exact-line test guards this.
  cat <<EOF
The project's declared test command is given literally on the next line — run it exactly as written to check your work (it is the project's own test entrypoint; do NOT assume any hard-coded test script):
TEST_CMD: $1
Run that command exactly as written above; the paragraphs that follow are separate instructions.
EOF
}

# The phase bodies come from the pack branch (D16); run-solo appends the
# handoff-section instructions (a control it owns) and the PHASE header. The
# code/verify phases also get the injected project test command (D22).
seed_prompts() {
  mkdir -p "$PROMPTS"
  local tc; tc="$(project_test_cmd)"
  write_prompt specify "$(load_role_body specify) $(handoff_instructions specify)"
  write_prompt code "$(load_role_body code) $(test_cmd_instructions "$tc") $(handoff_instructions code)"
  write_prompt verify "$(load_role_body verify) $(test_cmd_instructions "$tc") $(handoff_instructions verify)"
}

RUN_START="$(date +%s)"
check_run_deadline() { # <phase>: whole-run breaker (R10)
  [[ "$RUN_TIMEOUT" -gt 0 ]] || return 0
  if (( $(date +%s) - RUN_START >= RUN_TIMEOUT )); then
    fail_phase "$1" "whole-run timeout (${RUN_TIMEOUT}s) exceeded before phase could finish"
  fi
}

run_phase() { # <name> <workdir> ; returns 0 ok / non-zero on invoke failure
  local name="$1" wd="$2" rc=0
  set_status "running_$name"
  local runner=(bash "$ADAPTER_DIR/invoke" --workdir "$wd" --prompt-file "$PROMPTS/$name.prompt")
  if [[ "$PHASE_TIMEOUT" -gt 0 ]]; then
    runner=(bash "$FORK_ROOT/adapters/run-with-timeout" "$PHASE_TIMEOUT" -- "${runner[@]}")
  fi
  SOLO_HANDOFF="$HANDOFFS/$name.handoff" \
  SOLO_SPEC_DIR="$SPEC" \
  SOLO_PHASE="$name" \
  SOLO_PROJECT="$PROJECT" \
  SOLO_DIFF="$STATE/diff.patch" \
  SOLO_HANDOFFS_DIR="$HANDOFFS" \
    "${runner[@]}" > "$LOGS/$name.log" 2>&1 || rc=$?
  return $rc
}

# Per-phase breaker + retry cap (R10): run the phase, retrying a failed invoke
# up to --retry-cap times; exhausting the cap stops the run with attribution.
run_phase_with_retries() { # <name> <workdir>
  local name="$1" wd="$2" attempt=1 rc=0 last=""
  check_run_deadline "$name"
  while (( attempt <= RETRY_CAP )); do
    rc=0
    run_phase "$name" "$wd" || rc=$?
    if (( rc == 0 )); then return 0; fi
    if (( rc == 124 )); then last="per-phase timeout (${PHASE_TIMEOUT}s)"; else last="invoke failed (rc=$rc)"; fi
    echo "run-solo: phase '$name' attempt $attempt/$RETRY_CAP failed — $last" >&2
    attempt=$(( attempt + 1 ))
    check_run_deadline "$name"
  done
  fail_phase "$name" "exhausted retry cap ($RETRY_CAP); last failure: $last"
}

# validate a phase handoff; on failure, attribute and stop the run.
validate_phase_handoff() { # <name> [--changed]
  local name="$1"; shift || true
  local h="$HANDOFFS/$name.handoff"
  [[ -f "$h" ]] || fail_phase "$name" "no structured handoff written to $h"
  bb "$VALIDATE" "$h" "$@" 2>"$STATE/.verr" \
    || fail_phase "$name" "invalid handoff — $(tr -d '\n' < "$STATE/.verr")"
}

record_phase() { printf '%s\t%s\t%s\n' "$1" "$2" "$3" >> "$PHASES_TSV"; }

# R4/R9 owned-path enforcement (D17/D19): the candidate commit must touch only
# paths in project.prompt's owns: set. run-solo does NOT author the commit (the
# agent does — that is D17's root), so we do not silently re-scope it: we FAIL the
# run here, before verify ever judges the commit (R4), naming the offending paths.
enforce_owned_scope() {
  local baseline candidate
  baseline="$(cat "$STATE/baseline_commit")"
  candidate="$(cat "$STATE/candidate_commit")"
  local -a offenders=()
  local path g ok
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    ok=0
    for g in "${PROJECT_OWNS[@]}"; do [[ "$path" == $g ]] && { ok=1; break; }; done
    (( ok )) || offenders+=("$path")
  done < <(git -C "$PROJECT" diff --name-only "$baseline" "$candidate")
  if (( ${#offenders[@]} > 0 )); then
    fail_phase code "candidate commit touches paths outside the owned set (owns: ${PROJECT_OWNS[*]}); offending paths: ${offenders[*]}"
  fi
}

# --- specify + gate (fresh start) -------------------------------------------
start_fresh() {
  initialize_command_evidence_key
  mkdir -p "$SPEC" "$HANDOFFS" "$LOGS" "$APPROVAL" "$PROMPTS"
  : > "$PHASES_TSV"
  : > "$COMMANDS_TSV"
  git -C "$PROJECT" rev-parse --abbrev-ref HEAD > "$STATE/enforced_branch"
  git -C "$PROJECT" rev-parse HEAD > "$STATE/baseline_commit"
  seed_prompts

  local start; start="$(date +%s)"
  run_phase_with_retries specify "$PROJECT"
  finalize_handoff specify code
  validate_phase_handoff specify
  record_phase specify "$(( $(date +%s) - start ))" ok

  # R6 gate — pause for the owner's approval. The token is printed to THIS
  # console (never into an agent prompt or workdir). Its hash is kept in project
  # state; the same token is retained under runner-private state so the human can
  # approve through `craft-harness approve` without copying it by hand. D30's
  # same-user malicious-agent boundary still applies.
  local token
  token="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 32)"
  (umask 077; printf '%s' "$token" > "$APPROVAL_TOKEN")
  printf '%s' "$token" | sha256sum | awk '{print $1}' > "$APPROVAL/token.sha256"
  set_status "awaiting_approval"
  write_manifest "awaiting_approval"
  echo "run-solo: specify complete — spec at $SPEC (review spec.md and features/)."
  echo "run-solo: APPROVAL REQUIRED (R6). To approve the spec, write the token below to:"
  echo "run-solo:   $APPROVAL/APPROVED"
  echo "run-solo: approve with: craft-harness approve --project '$PROJECT'"
  echo "run-solo: then re-run: run-solo --project '$PROJECT' --adapter '$ADAPTER'"
  echo "APPROVAL_TOKEN: $token"
  exit 0
}

approved() {
  [[ -f "$APPROVAL/APPROVED" ]] || return 1
  local given expected
  given="$(printf '%s' "$(cat "$APPROVAL/APPROVED")" | sha256sum | awk '{print $1}')"
  expected="$(cat "$APPROVAL/token.sha256" 2>/dev/null || true)"
  [[ -n "$expected" && "$given" == "$expected" ]]
}

# D23: guarantee the code phase can AUTHOR its commit. run-solo instructs the
# agent to commit on the enforced branch, but a confined agent cannot configure a
# git identity (and cannot commit without one). If the project resolves no
# identity in any scope, seed a harness identity repo-locally — executable, never
# a prompt instruction. If the project already has one (local or global), leave it
# untouched. Backward compatible: toy projects that set their own identity are
# unaffected.
ensure_commit_identity() {
  if git -C "$PROJECT" config user.name  >/dev/null 2>&1 \
  && git -C "$PROJECT" config user.email >/dev/null 2>&1; then
    return 0
  fi
  git -C "$PROJECT" config user.name  "craft-harness"
  git -C "$PROJECT" config user.email "noreply@craft-harness.local"
}

run_project_command() { # <label> <exact shell command> <candidate workdir>
  local label="$1" command="$2" wd="$3" safe rc=0 start duration
  safe="${label//:/-}"
  start="$(date +%s)"
  set_status "running_$safe"
  bash "$FORK_ROOT/adapters/run-with-timeout" "$COMMAND_TIMEOUT" -- \
    bash -c 'cd "$1" && exec bash -c "$2"' _ "$wd" "$command" \
    > "$LOGS/command-$safe.log" 2>&1 || rc=$?
  duration=$(( $(date +%s) - start ))
  printf '%s\t%s\t%s\t%s\n' "$label" "$duration" "$rc" "$command" >> "$COMMANDS_TSV"
  if (( rc != 0 )); then
    if (( rc == 124 )); then
      fail_phase "$label" "declared command timed out after ${COMMAND_TIMEOUT}s: $command"
    fi
    fail_phase "$label" "declared command failed (rc=$rc): $command"
  fi
}

# --- code + verify (after approval) -----------------------------------------
run_code_and_verify() {
  local start
  seed_prompts   # idempotent — a resumed run picks up the current phase prompts
  ensure_commit_identity   # D23: the code phase must be able to author its commit

  # code phase — in the project, on the enforced branch.
  start="$(date +%s)"
  run_phase_with_retries code "$PROJECT"
  git -C "$PROJECT" rev-parse HEAD > "$STATE/candidate_commit"
  finalize_handoff code verify "$(git -C "$PROJECT" rev-parse --short=10 HEAD)"
  validate_phase_handoff code --changed
  record_phase code "$(( $(date +%s) - start ))" ok
  local candidate; candidate="$(cat "$STATE/candidate_commit")"
  local baseline; baseline="$(cat "$STATE/baseline_commit")"
  [[ "$candidate" != "$baseline" ]] || fail_phase code "no candidate commit produced (HEAD unchanged)"
  [[ "$(git -C "$PROJECT" rev-parse --abbrev-ref HEAD)" == "$(cat "$STATE/enforced_branch")" ]] \
    || fail_phase code "agent switched away from the enforced branch"
  git -C "$PROJECT" merge-base --is-ancestor "$baseline" "$candidate" \
    || fail_phase code "candidate is not descended from the recorded baseline"

  # R4/R9 (D17/D19): scope the candidate to the owned-path set BEFORE verify.
  enforce_owned_scope

  # verify phase — clean worktree at the candidate commit (B3). Restricted
  # inputs: the diff vs baseline + the handoffs travel via env; the worktree
  # itself carries no transcript or scratch from earlier phases.
  git -C "$PROJECT" diff "$baseline" "$candidate" > "$STATE/diff.patch"
  local vwd="$STATE/verify-workdir"
  rm -rf "$vwd"
  git -C "$PROJECT" worktree remove --force "$vwd" 2>/dev/null || true
  # The verifier MUST run against the candidate commit (R4 independent judgment).
  # CRAFT_SOLO_TEST_VERIFY_AT_BASELINE is a sanctioned test hook (D3-style) that
  # plants the mismatch — checking out the baseline instead — so the suite can
  # prove a wrong-commit worktree turns the run red. Never set in production.
  local verify_at="$candidate"
  [[ "${CRAFT_SOLO_TEST_VERIFY_AT_BASELINE:-}" == "1" ]] && verify_at="$baseline"
  VWD="$vwd"   # tracked so the EXIT trap tears it down even if a breaker fires
  git -C "$PROJECT" worktree add --detach "$vwd" "$verify_at" >/dev/null 2>&1 \
    || fail_phase verify "could not create verify worktree at $verify_at"

  start="$(date +%s)"
  run_phase_with_retries verify "$vwd"
  finalize_handoff verify done
  validate_phase_handoff verify
  record_phase verify "$(( $(date +%s) - start ))" ok
  if [[ -n "$(git -C "$vwd" status --porcelain --untracked-files=all)" ]]; then
    fail_phase verify "verifier modified its supposedly read-only candidate worktree"
  fi
  git -C "$PROJECT" worktree remove --force "$vwd" 2>/dev/null || true
  VWD=""

  # Runner-owned gates (D27): recreate a clean candidate worktree after every
  # agent has finished, then execute the exact project commands ourselves.
  VWD="$STATE/gate-workdir"
  git -C "$PROJECT" worktree add --detach "$VWD" "$candidate" >/dev/null 2>&1 \
    || fail_phase test "could not create command worktree at $candidate"
  run_project_command test "$PROJECT_TEST_CMD" "$VWD"
  local i
  for ((i=0; i<${#QUALITY_NAMES[@]}; i++)); do
    run_project_command "quality:${QUALITY_NAMES[$i]}" "${QUALITY_COMMANDS[$i]}" "$VWD"
  done
  git -C "$PROJECT" worktree remove --force "$VWD" 2>/dev/null || true
  VWD=""

  set_status "inspecting"
  write_manifest "success"
  if ! CRAFT_HARNESS_PRIVATE_STATE="$PRIVATE_STATE_ROOT" \
      bash "$FORK_ROOT/bin/inspect-run" "$STATE" "$PROJECT" > "$STATE/inspect-report.txt" 2>&1; then
    fail_phase inspect "post-run inspector rejected the evidence (see $STATE/inspect-report.txt)"
  fi
  set_status "done"
  write_manifest "success"
  cat "$STATE/inspect-report.txt"
  echo "run-solo: SUCCESS — all phases and runner-owned gates complete; evidence under $STATE"
}

# --- dispatch ---------------------------------------------------------------
if [[ ! -d "$STATE" ]]; then
  start_fresh
fi

case "$(cat "$STATUS" 2>/dev/null || echo unknown)" in
  awaiting_approval)
    if approved; then
      echo "run-solo: spec approved — resuming into code and verify."
      run_code_and_verify
    else
      echo "run-solo: still AWAITING APPROVAL — the spec has not been approved yet."
      echo "run-solo:   write the approval token to $APPROVAL/APPROVED, then re-run."
      exit 0
    fi
    ;;
  done)
    echo "run-solo: this session is already complete (status=done)."
    exit 0
    ;;
  failed)
    die "previous run failed ($(cat "$FAILURE" 2>/dev/null)). Remove $STATE to restart."
    ;;
  running_*)
    die "session in flight ($(cat "$STATUS")) — refusing to clobber. Investigate or remove $STATE to restart (R8)."
    ;;
  *)
    die "unrecognized session state; remove $STATE to restart."
    ;;
esac
