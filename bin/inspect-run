#!/usr/bin/env bash
# Deterministic solo-run evidence inspector. Agent prose is never a verdict.
set -euo pipefail

FORK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SESSION="${1:-}"; PROJECT="${2:-}"
[[ -d "$SESSION" && -d "$PROJECT/.git" ]] || { echo "usage: inspect-run <session-dir> <project>" >&2; exit 2; }
PROJECT="$(cd "$PROJECT" && pwd)"
MANIFEST="$SESSION/manifest.json"; COMMANDS="$SESSION/commands.tsv"
[[ -f "$MANIFEST" ]] || { echo "inspect-run: missing manifest.json" >&2; exit 2; }
command -v bb >/dev/null 2>&1 || { echo "inspect-run: babashka is required" >&2; exit 2; }

mapfile -t MF < <(bb "$FORK_ROOT/bin/inspect_manifest.bb" "$MANIFEST" \
  pack enforced_branch baseline_commit candidate_commit outcome command_evidence_mac)
PACK="${MF[0]:-}"; BRANCH="${MF[1]:-}"; BASELINE="${MF[2]:-}"
CANDIDATE="${MF[3]:-}"; OUTCOME="${MF[4]:-}"; RECORDED_COMMAND_MAC="${MF[5]:-}"
PRIVATE_STATE_ROOT="${CRAFT_HARNESS_PRIVATE_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/craft-harness}"
PROJECT_STATE_ID="$(printf '%s' "$PROJECT" | sha256sum | awk '{print $1}')"
# The runner-private key and the expected phase set are pack-specific. solo-pack
# is unchanged; six-pack (m7) adds harden/qa and the executable-Gherkin evidence.
declare -a PHASES=()
case "$PACK" in
  solo-pack) PACK_SUBDIR=solo; PHASES=(specify code verify) ;;
  six-pack)  PACK_SUBDIR=six;  PHASES=(specify code harden qa) ;;
  *)         PACK_SUBDIR=solo ;;   # check_manifest rejects an unsupported pack
esac
COMMAND_EVIDENCE_KEY="$PRIVATE_STATE_ROOT/$PACK_SUBDIR/$PROJECT_STATE_ID/commands.key"
declare -a RESULTS=(); FAILED=0
pass() { RESULTS+=("PASS $1"); }
fail() { RESULTS+=("FAIL $1: $2"); FAILED=1; }

check_manifest() {
  [[ "$PACK" == "solo-pack" || "$PACK" == "six-pack" ]] || { fail manifest "unsupported pack '$PACK'"; return; }
  [[ "$OUTCOME" == "success" ]] || { fail manifest "outcome is '$OUTCOME', not success"; return; }
  [[ "$BASELINE" =~ ^[0-9a-f]{40}$ && "$CANDIDATE" =~ ^[0-9a-f]{40}$ ]] \
    || { fail manifest "baseline/candidate commit is missing or malformed"; return; }
  git -C "$PROJECT" rev-parse --verify "$BASELINE^{commit}" >/dev/null 2>&1 \
    && git -C "$PROJECT" rev-parse --verify "$CANDIDATE^{commit}" >/dev/null 2>&1 \
    || { fail manifest "baseline or candidate does not resolve"; return; }
  [[ "$BASELINE" != "$CANDIDATE" ]] || { fail manifest "candidate did not advance"; return; }
  git -C "$PROJECT" merge-base --is-ancestor "$BASELINE" "$CANDIDATE" \
    || { fail manifest "candidate is not descended from baseline"; return; }
  [[ "$(git -C "$PROJECT" rev-parse HEAD)" == "$CANDIDATE" ]] \
    || { fail manifest "project HEAD is not the recorded candidate"; return; }
  [[ "$(git -C "$PROJECT" rev-parse --abbrev-ref HEAD)" == "$BRANCH" ]] \
    || { fail manifest "project is not on enforced branch '$BRANCH'"; return; }
  pass manifest
}

check_scope() {
  local contract owns path glob ok
  contract="$(bash "$FORK_ROOT/bin/parse-project" "$PROJECT/project.prompt" 2>&1)" \
    || { fail scope "invalid project contract: $contract"; return; }
  mapfile -t owns < <(printf '%s\n' "$contract" | awk -F '\t' '$1=="OWN" {print $2}')
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue; ok=0
    for glob in "${owns[@]}"; do [[ "$path" == $glob ]] && { ok=1; break; }; done
    (( ok )) || { fail scope "candidate touches out-of-scope path: $path"; return; }
  done < <(git -C "$PROJECT" diff --name-only "$BASELINE" "$CANDIDATE")
  pass scope
}

check_handoffs() {
  local phase h changed
  for phase in "${PHASES[@]}"; do
    h="$SESSION/handoffs/$phase.handoff"; [[ -f "$h" ]] \
      || { fail handoffs "missing $phase handoff"; return; }
    # code always commits; harden/qa self-declare via their commit: header, which
    # handoff-validate detects, so we don't force --changed on them.
    changed=(); [[ "$phase" == code ]] && changed=(--changed)
    bb "$FORK_ROOT/bin/handoff-validate.bb" "$h" "${changed[@]}" >/dev/null 2>&1 \
      || { fail handoffs "invalid $phase handoff"; return; }
  done
  pass handoffs
}

check_commands() {
  [[ -f "$COMMANDS" ]] || { fail commands "missing runner-owned commands.tsv"; return; }
  [[ "$RECORDED_COMMAND_MAC" =~ ^[0-9a-f]{64}$ ]] \
    || { fail commands "missing or malformed command evidence authenticator"; return; }
  [[ -f "$COMMAND_EVIDENCE_KEY" ]] \
    || { fail commands "runner-private command evidence key is unavailable"; return; }
  # The six-pack authenticator additionally covers the executable-Gherkin evidence
  # (the acceptance report + the approved-scenario snapshot) AND the mutation report
  # (D35), matching run-six's recipe exactly; solo-pack's recipe is unchanged. The
  # mutation report is absent unless mutation is declared, so its empty `cat` keeps
  # the recipe byte-identical for six-pack runs without a mutation gate.
  local actual_mac
  if [[ "$PACK" == "six-pack" ]]; then
    actual_mac="$({ cat "$COMMAND_EVIDENCE_KEY"; printf '%s\n%s\n' "$PROJECT" "$CANDIDATE"; \
      cat "$COMMANDS"; \
      cat "$SESSION/accept-report.ndjson" 2>/dev/null || true; \
      cat "$SESSION/spec/approved-scenarios.txt" 2>/dev/null || true; \
      cat "$SESSION/mutation-report.xml" 2>/dev/null || true; \
      cat "$COMMAND_EVIDENCE_KEY"; } | sha256sum | awk '{print $1}')"
  else
    actual_mac="$({ cat "$COMMAND_EVIDENCE_KEY"; printf '%s\n%s\n' "$PROJECT" "$CANDIDATE"; \
      cat "$COMMANDS"; cat "$COMMAND_EVIDENCE_KEY"; } | sha256sum | awk '{print $1}')"
  fi
  [[ "$actual_mac" == "$RECORDED_COMMAND_MAC" ]] \
    || { fail commands "command evidence authentication failed (record was tampered with)"; return; }
  local contract expected=() actual=() kind a b c label duration rc command i
  contract="$(bash "$FORK_ROOT/bin/parse-project" "$PROJECT/project.prompt" 2>&1)" \
    || { fail commands "invalid project contract: $contract"; return; }
  while IFS=$'\t' read -r kind a b c; do
    case "$kind" in
      TEST) expected+=("test" "$a");;
      QUALITY) expected+=("quality:$a" "$b");;
      ACCEPT) expected+=("accept" "$a");;
      MUTATION) [[ "$PACK" == "six-pack" ]] && expected+=("mutation" "$c");;
    esac
  done <<< "$contract"
  while IFS=$'\t' read -r label duration rc command; do
    [[ -n "$label" ]] || continue
    [[ "$duration" =~ ^[0-9]+$ && "$rc" == "0" ]] \
      || { fail commands "command '$label' did not complete successfully"; return; }
    actual+=("$label" "$command")
  done < "$COMMANDS"
  (( ${#expected[@]} == ${#actual[@]} )) \
    || { fail commands "executed command set does not match the project contract"; return; }
  for ((i=0; i<${#expected[@]}; i++)); do
    [[ "${expected[$i]}" == "${actual[$i]}" ]] \
      || { fail commands "executed command structure differs from the project contract"; return; }
  done
  pass commands
}

# Executable-Gherkin re-verification (six-pack only, m7): independently re-check
# that every approved snapshot scenario is reported PASSED — structurally, via the
# report parser, never by substring. run-six already enforced this live and
# fail-closed; this is the D2 defense-in-depth re-check over the authenticated
# retained evidence.
check_scenarios() {
  local report="$SESSION/accept-report.ndjson" snap="$SESSION/spec/approved-scenarios.txt"
  [[ -f "$report" ]] || { fail scenarios "missing acceptance report"; return; }
  [[ -s "$snap" ]] || { fail scenarios "missing or empty approved-scenario snapshot"; return; }
  local parsed id st
  parsed="$(bb "$FORK_ROOT/bin/parse-accept-report.bb" "$report" 2>&1)" \
    || { fail scenarios "acceptance report unparseable: $parsed"; return; }
  declare -A passed=()
  while IFS=$'\t' read -r id st; do [[ -n "$id" && "$st" == passed ]] && passed["$id"]=1; done <<< "$parsed"
  while IFS= read -r id; do
    [[ -n "$id" ]] || continue
    [[ -n "${passed[$id]:-}" ]] || { fail scenarios "approved scenario not passed in the report: $id"; return; }
  done < "$snap"
  pass scenarios
}

# Mutation-gate re-verification (six-pack only, D35): when the contract declares a
# mutation gate, independently re-derive the real score from the authenticated
# retained report and re-check it against the PROJECT-declared threshold — runner-
# owned, structural, not agent-claimed. Absent declaration -> no mutation gate, no
# check added (opt-in; a six-pack without mutation is unaffected).
check_mutation() {
  local contract line tool threshold command killed total
  contract="$(bash "$FORK_ROOT/bin/parse-project" "$PROJECT/project.prompt" 2>&1)" \
    || { fail mutation "invalid project contract: $contract"; return; }
  line="$(printf '%s\n' "$contract" | awk -F '\t' '$1=="MUTATION"{print; exit}')"
  [[ -n "$line" ]] || return 0    # mutation not declared -> nothing to check
  IFS=$'\t' read -r _ tool threshold command <<< "$line"
  local report="$SESSION/mutation-report.xml"
  [[ -f "$report" ]] || { fail mutation "missing mutation report"; return; }
  local parsed
  parsed="$(bb "$FORK_ROOT/bin/parse-mutation-report.bb" "$report" 2>&1)" \
    || { fail mutation "mutation report unparseable: $parsed"; return; }
  IFS=$'\t' read -r killed total <<< "$parsed"
  (( killed * 100 >= 10#$threshold * total )) \
    || { fail mutation "mutation score below declared threshold ${threshold}% (${killed}/${total} killed)"; return; }
  pass mutation
}

check_manifest
check_scope
check_handoffs
check_commands
[[ "$PACK" == "six-pack" ]] && check_scenarios
[[ "$PACK" == "six-pack" ]] && check_mutation

echo "inspect-run — $PACK session $SESSION against project $PROJECT"
for result in "${RESULTS[@]}"; do
  if [[ "$result" == PASS* ]]; then echo "  [x] ${result#PASS }"; else echo "  [ ] ${result#FAIL }"; fi
done
if (( FAILED )); then echo "RESULT: FAIL"; exit 1; fi
echo "RESULT: PASS"
